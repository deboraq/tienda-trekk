rules_version = '2';

// Mismo email admin que en firestore.rules (subida de fotos a productos/).
service firebase.storage {
  match /b/{bucket}/o {
    match /productos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "debocab2@gmail.com";
    }
  }
}
