rules_version = '2';

// Reemplazá "tu-correo-admin@gmail.com" por el email de tu usuario en Firebase Authentication
// (mismo valor que en storage.rules). Luego publicá reglas en la consola o con Firebase CLI.
service cloud.firestore {
  match /databases/{database}/documents {
    function isCatalogAdmin() {
      return request.auth != null
        && request.auth.token.email == "tu-correo-admin@gmail.com";
    }

    match /productos/{productId} {
      allow read: if true;
      allow create: if isCatalogAdmin();
      allow update, delete: if isCatalogAdmin();
    }
  }
}
